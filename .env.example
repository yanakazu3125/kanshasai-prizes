PORT=3001
SESSION_SECRET=change-me
# MongoDB（本番/Render用）
MONGODB_URI=
# Cloudinary（画像を永続化する場合）
# どちらかでOK:
# - CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# - CLOUDINARY_CLOUD_NAME / CLOUDINARY_API_KEY / CLOUDINARY_API_SECRET
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=kanshasai-prizes
# 1にすると、同じ画像はCloudinary上で使い回し（内容ハッシュで重複排除）
# ※この場合、他の商品と共有される可能性があるため自動削除は行いません
CLOUDINARY_DEDUP=1
# 画像未設定時のデフォルト（ローカル用）
DEFAULT_IMAGE_PATH=/image/IMG_0428.jpg
# 初期管理者（ローカル用）
ADMIN_ID=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
