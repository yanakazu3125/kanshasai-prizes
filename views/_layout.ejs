<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/style.css" />
  </head>
  <body class="<%= (typeof bodyClass !== 'undefined' && bodyClass) ? bodyClass : '' %>">
    <div class="container">
      <div class="topbar">
        <div class="brand">
          <a href="/prizes" style="text-decoration:none;">
            <span class="brandMain">オーセモーション・プロダクツ</span>
            <span class="brandSub">景品紹介</span>
          </a>
        </div>
        <div class="nav">
          <a class="pill" href="/prizes">一覧</a>
          <% if (user) { %>
            <a class="pill" href="/admin/prizes">管理</a>
            <form method="post" action="/admin/logout" style="margin:0;">
              <button class="pill" type="submit" style="cursor:pointer;">ログアウト</button>
            </form>
          <% } else { %>
            <a class="pill" href="/admin/login">ログイン</a>
          <% } %>
        </div>
      </div>

      <%- body %>
    </div>
  </body>
</html>

